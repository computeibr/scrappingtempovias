# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere uma string aleatória forte, ex: openssl rand -hex 32
SECRET=troque_por_uma_string_secreta_forte

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB=tempovias
DB_USER=tempovias_user
DB_PASS=troque_pela_sua_senha
DB_HOST=postgres   # nome do serviço no docker-compose (não alterar em produção)
DB_PORT=5432
DB_SSL=false       # mude para true se usar banco externo com SSL (ex: Supabase, Neon)
